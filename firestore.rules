rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user is the owner
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // Helper function to check if user is an admin (Super Admin)
    function isSuperAdmin() {
      return exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    // Helper function to check if user is a Hospital Admin
    function isHospitalAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.userType == 'hospital';
    }

    // Unified admin check
    function isAdmin() {
      return isSuperAdmin() || isHospitalAdmin();
    }
    
    // ==================== TICKETS COLLECTION ====================
    
    match /tickets/{ticketId} {
      // Allow read if user is the ticket creator or assigned admin
      allow get: if isAuthenticated() && (
        isOwner(resource.data.userId) || 
        isAdmin() ||
        (resource.data.assignedAdminId == request.auth.uid)
      );
      
      allow list: if isAuthenticated() && (
        // Users can only see their own tickets
        request.query.keys().hasOnly(['userId']) && request.query['userId'] == request.auth.uid
        ||
        // Admins can see all tickets
        isAdmin()
      );
      
      // Allow create if authenticated and setting own userId
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.keys().hasAll(['userId', 'userName', 'userEmail', 'type', 'priority', 'subject', 'description']);
      
      // Allow update if:
      // - User is the creator (can only update certain fields)
      // - Admin is assigned (can update all fields)
      allow update: if isAuthenticated() && (
        // Admin can update anything
        isAdmin() ||
        (resource.data.assignedAdminId == request.auth.uid) ||
        // User can only update status to 'closed' or add messages
        (isOwner(resource.data.userId) && 
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'closedAt', 'updatedAt']) ||
           request.resource.data.status == 'closed')
        )
      );
      
      // Allow delete only by admins
      allow delete: if isAdmin();
    }
    
    // ==================== TICKET MESSAGES COLLECTION ====================
    
    match /ticketMessages/{messageId} {
      // Allow read if user is involved in the ticket
      allow get: if isAuthenticated() && (
        let ticket = get(/databases/$(database)/documents/tickets/$(resource.data.ticketId)).data;
        ticket.userId == request.auth.uid || 
        ticket.assignedAdminId == request.auth.uid ||
        isAdmin()
      );
      
      allow list: if isAuthenticated() && (
        let ticket = get(/databases/$(database)/documents/tickets/$(request.query['ticketId'])).data;
        request.query.keys().hasOnly(['ticketId']) && (
          ticket.userId == request.auth.uid || 
          ticket.assignedAdminId == request.auth.uid ||
          isAdmin()
        )
      );
      
      // Allow create if authenticated and sender is involved in the ticket
      allow create: if isAuthenticated() && 
        request.resource.data.keys().hasAll(['ticketId', 'senderId', 'senderName', 'senderType', 'message']) &&
        let ticket = get(/databases/$(database)/documents/tickets/$(request.resource.data.ticketId)).data;
        (ticket.userId == request.auth.uid && request.resource.data.senderType == 'user') ||
        (ticket.assignedAdminId == request.auth.uid && request.resource.data.senderType == 'admin') ||
        isAdmin();
      
      // Allow update only by message sender or admin
      allow update: if isAuthenticated() && (
        resource.data.senderId == request.auth.uid ||
        isAdmin()
      );
      
      // Allow delete only by admins
      allow delete: if isAdmin();
    }
    
    // ==================== TICKET AUDIT LOGS COLLECTION ====================
    
    match /ticketAuditLogs/{auditId} {
      // Allow read if user is involved in the ticket or is admin
      allow get, list: if isAuthenticated() && (
        let audit = get(/databases/$(database)/documents/ticketAuditLogs/$(auditId)).data;
        let ticket = get(/databases/$(database)/documents/tickets/$(audit.ticketId)).data;
        ticket.userId == request.auth.uid || 
        ticket.assignedAdminId == request.auth.uid ||
        isAdmin()
      );
      
      // Allow create only by system (via Cloud Functions) or admins
      allow create: if isAuthenticated() && (
        isAdmin() ||
        request.resource.data.performedBy == request.auth.uid
      );
      
      // Deny all other operations
      allow update, delete: if false;
    }
    
    // ==================== EXISTING COLLECTIONS (for reference) ====================
    
    match /users/{userId} {
      allow get: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow list: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow delete: if isOwner(userId) || isAdmin();
    }
    
    match /bloodRequests/{requestId} {
      allow get, list: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.requesterId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.requesterId == request.auth.uid || 
        resource.data.acceptedDonorId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAuthenticated() && (
        resource.data.requesterId == request.auth.uid ||
        isAdmin()
      );
    }
    
    match /acceptedRequests/{acceptedRequestId} {
      allow get: if isAuthenticated() && (
        resource.data.donorId == request.auth.uid || 
        resource.data.requesterId == request.auth.uid ||
        isAdmin()
      );
      allow list: if isAuthenticated() && (
        request.query.keys().hasOnly(['donorId']) && request.query['donorId'] == request.auth.uid
        ||
        request.query.keys().hasOnly(['requesterId']) && request.query['requesterId'] == request.auth.uid
        ||
        isAdmin()
      );
      allow create: if isAuthenticated() && request.resource.data.donorId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.donorId == request.auth.uid || 
        resource.data.requesterId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }
    
    match /chats/{chatId} {
      allow get: if isAuthenticated() && (
        resource.data.participants.hasAny([request.auth.uid]) ||
        isAdmin()
      );
      allow list: if isAuthenticated() && (
        request.query.keys().hasOnly(['participants']) &&
        isAdmin()
      );
      allow create: if isAuthenticated() && request.resource.data.participants.hasAny([request.auth.uid]);
      allow update: if isAuthenticated() && (
        resource.data.participants.hasAny([request.auth.uid]) ||
        isAdmin()
      );
      allow delete: if isAuthenticated() && (
        resource.data.participants.hasAny([request.auth.uid]) ||
        isAdmin()
      );
    }
    
    match /messages/{messageId} {
      allow get, list: if isAuthenticated() && (
        resource.data.senderId == request.auth.uid || 
        resource.data.receiverId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.senderId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }
    
    match /notifications/{notificationId} {
      allow get, list: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuthenticated() && (
        request.resource.data.userId == request.auth.uid ||
        isAdmin()
      );
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        isAdmin()
      );
    }
    
    match /verification_requests/{userId} {
      allow get: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow list: if isAdmin();
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin());
    }
    
    match /donations/{donationId} {
      allow get: if isAuthenticated() && (
        resource.data.donorId == request.auth.uid ||
        isAdmin()
      );
      allow list: if isAuthenticated() && (
        request.query.keys().hasOnly(['donorId']) && request.query['donorId'] == request.auth.uid
        ||
        isAdmin()
      );
      allow create: if isAuthenticated() && request.resource.data.donorId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    match /posts/{postId} {
      allow get, list: if true;  // Public feed
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        isAdmin()
      );
    }
    
    match /reviews/{reviewId} {
      allow get, list: if true;  // Public reviews
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    match /interestedDonors/{interestId} {
      allow get: if isAuthenticated();
      allow list: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.donorId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.donorId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }
    
    match /rejectedRequests/{rejectionId} {
      allow get: if isAuthenticated() && resource.data.donorId == request.auth.uid;
      allow list: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.donorId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
    
    // Admins collection (for admin role checking)
    match /admins/{userId} {
      allow get: if isAuthenticated();
      allow list: if false;
      allow create, update, delete: if false;  // Only via Firebase Console or Admin SDK
    }
    
    // Blood banks (read-only for users)
    match /bloodBanks/{bankId} {
      allow get, list: if true;  // Public
      allow create, update, delete: if isAdmin();
    }
    
    match /bloodBankInventory/{inventoryId} {
      allow get, list: if true;  // Public
      allow create, update, delete: if isAdmin();
    }
  }
}
